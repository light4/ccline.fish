#!/usr/bin/env bash
#
# ccline — type a thought at your shell, get an answer.
#
# This is the helper invoked by command_not_found_handler (see ccline.zsh).
# It sends the thought to the `claude` CLI, prints the answer, and offers to
# run any shell commands the answer contains.
#
# It can also be sourced (tests do this) without running main(): the dispatch
# at the bottom only runs when the file is executed directly.

set -uo pipefail

# Optional model override, e.g. CCLINE_MODEL=claude-haiku-4-5-20251001
CCLINE_MODEL="${CCLINE_MODEL:-}"

ccline_system_prompt() {
  cat <<'EOF'
You are a command-line assistant answering a quick question typed directly at a
macOS zsh prompt. Be concise — a few sentences at most. If your answer involves
shell commands the user can run, put each runnable command in its own fenced
```bash code block. Never put example output, file contents, or non-runnable
snippets in a bash/sh/shell block. Prefer safe, non-destructive commands; if a
command is destructive, say so plainly.
EOF
}

# Read an answer on stdin, print the lines that live inside ```bash / ```sh /
# ```shell fenced blocks (one line per command, order preserved).
ccline_extract_commands() {
  awk '
    /^[[:space:]]*```/ {
      if (infence) { infence = 0; next }
      info = $0
      sub(/^[[:space:]]*```/, "", info)
      gsub(/[[:space:]]/, "", info)
      info = tolower(info)
      if (info == "bash" || info == "sh" || info == "shell") infence = 1
      next
    }
    infence { print }
  '
}

# Keep only runnable lines: drop blank lines and comment-only lines.
ccline_runnable_lines() {
  grep -vE '^[[:space:]]*($|#)' || true
}

# Render Markdown on stdin to ANSI for terminal display. Falls back to raw
# output if there is a glow binary (preferred) or, finally, plain text.
ccline_render() {
  if command -v glow >/dev/null 2>&1; then
    glow - 2>/dev/null && return 0
  fi
  perl -e '
    my $in = 0;
    my ($B,$D,$C,$G,$I,$R) = ("\e[1m","\e[2m","\e[36m","\e[32m","\e[3m","\e[0m");
    while (my $l = <STDIN>) {
      chomp $l;
      if ($l =~ /^\s*```/) { $in = !$in; next; }   # hide fence markers
      if ($in)             { print "${G}    $l${R}\n"; next; }  # code: green, indented
      if ($l =~ /^(#{1,6})\s+(.*)/) { print "${B}$2${R}\n"; next; }   # heading
      $l =~ s/^(\s*)[-*]\s+/$1• /;                 # bullets
      $l =~ s/`([^`]+)`/${C}$1${R}/g;              # inline code
      $l =~ s/\*\*([^*]+)\*\*/${B}$1${R}/g;        # **bold**
      $l =~ s/(?<!\*)\*([^*]+)\*(?!\*)/${I}$1${R}/g; # *italic*
      print "$l\n";
    }
  '
}

# True when we have an interactive terminal we can read keystrokes from.
ccline_can_interact() {
  [ -t 1 ] || return 1
  ( exec < /dev/tty ) 2>/dev/null || return 1
  return 0
}

# Arrow-key menu. Args are the labels. Draws to /dev/tty and echoes the chosen
# 0-based index to stdout. ↑/↓ (or k/j) move, Enter confirms, q cancels (which
# selects the last item — callers make that "Cancel").
ccline_menu() {
  local -a items=("$@")
  local n="${#items[@]}"
  local sel=0 ESC=$'\e' tty=/dev/tty i key rest first=1
  local UP="${ESC}[A" DOWN="${ESC}[B" NL=$'\n' CR=$'\r'

  local saved
  saved="$(stty -g < "$tty" 2>/dev/null)"
  stty -echo -icanon min 1 time 0 < "$tty" 2>/dev/null    # raw, no echo
  printf '%s[?25l' "$ESC" > "$tty"                        # hide cursor
  trap 'stty "$saved" < "$tty" 2>/dev/null; printf "%s[?25h" "$ESC" > "$tty" 2>/dev/null; trap - INT; kill -INT $$' INT

  while :; do
    if [ "$first" -eq 1 ]; then
      first=0
    else
      printf '%s[%dA' "$ESC" "$n" > "$tty"               # cursor up n lines
    fi
    for (( i = 0; i < n; i++ )); do
      if [ "$i" -eq "$sel" ]; then
        printf '%s[2K%s[7m ❯ %s %s[0m\n' "$ESC" "$ESC" "${items[i]}" "$ESC" > "$tty"
      else
        printf '%s[2K   %s\n' "$ESC" "${items[i]}" > "$tty"
      fi
    done

    IFS= read -rsn1 key < "$tty" || break
    if [ "$key" = "$ESC" ]; then
      IFS= read -rsn2 rest < "$tty"                      # consume "[A"/"[B"
      key="$key$rest"
    fi

    if [ "$key" = "$UP" ] || [ "$key" = k ]; then
      sel=$(( (sel - 1 + n) % n ))
    elif [ "$key" = "$DOWN" ] || [ "$key" = j ]; then
      sel=$(( (sel + 1) % n ))
    elif [ -z "$key" ] || [ "$key" = "$NL" ] || [ "$key" = "$CR" ]; then
      break                                              # Enter
    elif [ "$key" = q ] || [ "$key" = Q ]; then
      sel=$(( n - 1 )); break                            # cancel → last item
    fi
  done

  printf '%s[?25h' "$ESC" > "$tty"                       # show cursor
  stty "$saved" < "$tty" 2>/dev/null                     # restore terminal
  trap - INT
  printf '%s\n' "$sel"
}

ccline_main() {
  if [ "$#" -eq 0 ]; then
    echo "usage: ccline <your thought>" >&2
    return 2
  fi

  if ! command -v claude >/dev/null 2>&1; then
    echo "ccline: 'claude' CLI not found. Install Claude Code: https://claude.com/claude-code" >&2
    return 127
  fi

  local prompt="$*"
  local sys
  sys="$(ccline_system_prompt)"

  local model_args=()
  [ -n "$CCLINE_MODEL" ] && model_args=(--model "$CCLINE_MODEL")

  # Clean, isolated call: no default agent prompt, no tools, no settings
  # (CLAUDE.md etc.), no MCP servers, plain-text output. Just the question plus
  # our tiny system prompt that drives the run-commands feature.
  local answer rc
  answer="$(claude -p \
    --system-prompt "$sys" \
    --tools "" \
    --setting-sources "" \
    --strict-mcp-config \
    --output-format text \
    ${model_args[@]+"${model_args[@]}"} \
    "$prompt")"
  rc=$?
  if [ "$rc" -ne 0 ]; then
    echo "ccline: claude exited with status $rc" >&2
    return "$rc"
  fi
  if [ -z "${answer//[[:space:]]/}" ]; then
    echo "ccline: empty response from claude" >&2
    return 1
  fi

  # Render Markdown only when writing to a terminal; raw otherwise (pipes, files).
  if [ -t 1 ]; then
    printf '%s\n' "$answer" | ccline_render
  else
    printf '%s\n' "$answer"
  fi

  local runnable
  runnable="$(printf '%s\n' "$answer" | ccline_extract_commands | ccline_runnable_lines)"
  [ -z "$runnable" ] && return 0

  local -a cmds=()
  local line
  while IFS= read -r line; do
    [ -n "$line" ] && cmds+=("$line")
  done <<< "$runnable"
  local n="${#cmds[@]}"
  [ "$n" -eq 0 ] && return 0

  local i
  local -a to_run=()

  if ccline_can_interact; then
    # Build menu labels: each command, optional "Run all", then "Cancel".
    local -a labels=("${cmds[@]}")
    local all_idx=-1
    if [ "$n" -gt 1 ]; then
      labels+=("➤ Run all of them")
      all_idx=$(( ${#labels[@]} - 1 ))
    fi
    labels+=("✗ Cancel")
    local cancel_idx=$(( ${#labels[@]} - 1 ))

    echo
    echo "Commands found — ↑/↓ to choose, Enter to run, q to cancel:"
    local choice
    choice="$(ccline_menu "${labels[@]}")"

    if [ "$choice" -ge 0 ] 2>/dev/null && [ "$choice" -ne "$cancel_idx" ]; then
      if [ "$all_idx" -ge 0 ] && [ "$choice" -eq "$all_idx" ]; then
        to_run=("${cmds[@]}")
      elif [ "$choice" -lt "$n" ]; then
        to_run=("${cmds[$choice]}")
      fi
    fi
  else
    # Non-interactive (piped / no tty): typed-number prompt.
    echo
    echo "Commands found:"
    for i in "${!cmds[@]}"; do
      printf '  %d. %s\n' "$((i + 1))" "${cmds[i]}"
    done
    if [ "$n" -eq 1 ]; then
      printf 'Run it? [y/N] '
    else
      printf 'Run which? [1-%d, a=all, Enter=none] ' "$n"
    fi
    local ans=""
    IFS= read -r ans || ans=""
    case "$ans" in
      a | A) to_run=("${cmds[@]}") ;;
      y | Y) [ "$n" -eq 1 ] && to_run=("${cmds[0]}") ;;
      '' | n | N) ;;
      *[!0-9]*) ;;                                # not a number → run nothing
      *) if [ "$ans" -ge 1 ] && [ "$ans" -le "$n" ]; then
           to_run=("${cmds[$((ans - 1))]}")
         fi ;;
    esac
  fi

  [ "${#to_run[@]}" -eq 0 ] && return 0

  # When invoked from the zsh handler, hand the selection back so it runs in the
  # user's live shell (cd/export/aliases/history all work). Otherwise run it
  # ourselves (direct invocation, pipes, non-zsh shells).
  if [ -n "${CCLINE_RUN_FILE:-}" ]; then
    : > "$CCLINE_RUN_FILE"
    for line in "${to_run[@]}"; do
      printf '%s\n' "$line" >> "$CCLINE_RUN_FILE"
    done
    return 0
  fi

  for line in "${to_run[@]}"; do
    printf '$ %s\n' "$line"
    if ! eval "$line"; then
      rc=$?
      echo "ccline: command failed (exit $rc); stopping." >&2
      return "$rc"
    fi
  done
}

# Only run when executed directly, not when sourced (tests source this file).
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  ccline_main "$@"
fi
